{
  "name": "nebur-regex",
  "version": "1.5.2",
  "description": "A powerful utility package designed to streamline the developer experience with regular expressions. With an intuitive and expressive API, it provides a convenient way to create, combine, and apply regular expression validation rules in your JavaScript or TypeScript projects",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist/index.js",
    "dist/index.mjs",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "prepare:hooks": "husky",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --follow-tags",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint --fix src/**/*.ts",
    "test": "jest",
    "test:cov": "jest --coverage",
    "build": "npm run clean && esbuild src/index.ts --bundle --minify --platform=node --target=node18 --format=cjs --outfile=dist/index.js && esbuild src/index.ts --bundle --minify --platform=node --target=node18 --format=esm --outfile=dist/index.mjs && tsc --emitDeclarationOnly --declaration --outDir dist --rootDir src",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "pack:size": "npm run build && npm pack --dry-run --json --ignore-scripts",
    "release:patch": "npm version patch --sign-git-tag",
    "release:minor": "npm version minor --sign-git-tag",
    "release:major": "npm version major --sign-git-tag"
  },
  "author": "Nebur242",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-typescript": "^7.23.3",
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.2",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.56.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "resolve.exports": "^2.0.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.{ts, json}": [
      "npm run format",
      "npm run lint:fix"
    ]
  },
  "keywords": [
    "regex",
    "string",
    "JS",
    "Regular expressions"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "url": "https://github.com/Nebur242/nebur-regex"
  }
}
